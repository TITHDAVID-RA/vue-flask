# Azure Key Vault Configuration
AZURE_KEY_VAULT_NAME=secureshop-kv
AZURE_KEY_VAULT_URL=https://secureshop-kv.vault.azure.net

# Flask Configuration
FLASK_ENV=development
FLASK_SECRET_KEY=your-flask-secret-key

# Database (fallback if not in Key Vault)
DATABASE_URL=sqlite:///ecommerce.db

# JWT Secret (fallback if not in Key Vault)
JWT_SECRET_KEY=your-jwt-secret-key

# Stripe Keys (fallback if not in Key Vault)
STRIPE_SECRET_KEY=sk_test_your_stripe_secret_key
STRIPE_PUBLISHABLE_KEY=pk_test_your_stripe_publishable_key
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret

# CORS Origins
CORS_ORIGINS=http://localhost:8080,http://localhost:3000
